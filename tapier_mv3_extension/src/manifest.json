{
	"manifest_version": 3,
	"name": "TAPier",
	"version": "1.0.0",
	"description": "The TAPier extension, missionary of Japanese learning.",
	"icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
	"permissions": ["sidePanel", "contextMenus", "storage"],
	"host_permissions": ["<all_urls>"],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_title": "TAPier inspector"
	},
	"side_panel": {
		"default_path": "side_panel/side_panel.html"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content_script.js"],
			"run_at": "document_idle"
		}
	]
}